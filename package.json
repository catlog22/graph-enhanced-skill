{
  "name": "graph-enhanced-skill",
  "version": "1.0.0",
  "description": "GES — Graph-Enhanced Skill Standard. Formalize AI agent skill state machines as YAML graph structures with nodes, edges, actions, and bindings.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ges": "dist/cli.js"
  },
  "files": [
    "dist/",
    "schema/",
    "examples/",
    "SPEC.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.ts",
    "test": "tsx --test src/__tests__/*.test.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "skill",
    "state-machine",
    "graph",
    "yaml",
    "workflow",
    "orchestration",
    "ges"
  ],
  "author": "catlog22",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/catlog22/graph-enhanced-skill.git"
  },
  "homepage": "https://github.com/catlog22/graph-enhanced-skill#readme",
  "dependencies": {
    "ajv": "^8.20.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
